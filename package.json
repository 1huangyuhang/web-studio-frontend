{
  "name": "enterprise-frontend-framework",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "npm run dev --prefix backend",
    "dev:management": "vite --config vite.config.management.ts --base /",
    "build": "tsc && vite build",
    "build:management": "tsc -p management/tsconfig.json && vite build --config vite.config.management.ts",
    "check:management-routes": "node scripts/verify-management-menu-routes.mjs",
    "check:management-api": "node scripts/check-management-api.mjs",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage",
    "test:management": "jest --config management/jest.config.cjs",
    "test:all:unit": "npm run test && npm run test:management",
    "test:backend": "cd backend && npm test",
    "test:backend:regression": "cd backend && npm run test:regression",
    "test:backend:coverage": "cd backend && npm run test:coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:load": "node scripts/load-test.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "prepare": "husky install",
    "start:all": "concurrently --names 'backend,main,management,prisma,browser' --prefix-colors 'blue,green,yellow,red,purple' --kill-others-on-fail --prefix '[{name}]' --timestamp-format 'HH:mm:ss' 'cd backend && npm run dev' 'npm run dev' 'npm run dev:management' 'cd backend && npx prisma studio' './open-browser.sh' --success-condition 'all'"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.1",
    "@tanstack/react-query": "^5.90.12",
    "antd": "^6.1.0",
    "axios": "^1.14.0",
    "dayjs": "^1.11.19",
    "less": "^4.4.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^8.6.18",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react-vite": "^8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autocannon": "^8.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "rollup-plugin-visualizer": "^6.0.5",
    "storybook": "^8.6.18",
    "ts-jest": "^29.4.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  }
}
