# PostgreSQL（Prisma）
# 开发：直连实例即可。生产建议按托管方文档使用连接池 / PgBouncer（注意 Prisma 与 pooler 模式、
# prepared_statements 等参数是否与官方矩阵兼容）。
# 参考：Prisma 文档「Connection pool」、托管平台（Neon、Supabase、RDS）推荐 URL。
DATABASE_URL="postgresql://postgres:password@localhost:5432/database_name?schema=public"

# 服务器配置（管理端 dev 时 Vite 代理默认连此端口；与仓库 scripts/dev-ports.env 的 REDWOOD_PORT_API 保持一致）
PORT=3000
NODE_ENV=development

# API认证配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password
# 与官网/管理端构建时的 VITE_API_KEY 须一致（见根目录 .env.example、management/.env.example）
API_KEY=default-api-key

# JWT（登录令牌；缺少或过短会导致后端无法启动）
# 请替换为至少 32 字符的随机串，勿提交真实密钥到版本库
JWT_SECRET=replace-with-at-least-32-char-random-secret-string
# 可选，如 7d、24h；未设置时代码默认 7d
# JWT_EXPIRES_IN=7d

# 管理类 API：允许携带 JWT 的角色（逗号分隔）。未设置时默认 ADMIN,USER
# MANAGEMENT_JWT_ROLES=ADMIN,USER

# 设为 1 时，JWT 角色为 USER 的账号仅允许读接口（与 management 端 VITE_MANAGEMENT_USER_READONLY 配合）
# MANAGEMENT_USER_READONLY=1

# 可选：单独运行 userSeed.ts 写入/刷新默认管理员时使用（主 npm run seed 不会自动执行）
# ADMIN_EMAIL=admin@example.com
# ADMIN_USERNAME_SEED=admin
# ADMIN_INITIAL_PASSWORD=ChangeMe_Admin1!

# Prisma配置
PRISMA_LOG_LEVEL=error

# 日志配置
LOG_LEVEL=info
